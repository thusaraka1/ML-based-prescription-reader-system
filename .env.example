# CareConnect Environment Configuration
# Copy this file to .env and fill in your API keys

# Google Cloud Healthcare NLP API
VITE_GOOGLE_CLOUD_API_KEY=
VITE_GOOGLE_CLOUD_PROJECT_ID=

# Gemini API (for prescription verification + meal planning)
VITE_GEMINI_API_KEY=

# Feature Flags
VITE_ENABLE_CLOUD_NLP=true
VITE_ENABLE_GEMINI_VERIFICATION=true
VITE_ENABLE_MEAL_SUGGESTIONS=true

# Custom Donut Model Backend (run: cd server && python donut_server.py)
VITE_DONUT_API_URL=http://localhost:8000
VITE_ENABLE_CUSTOM_MODEL=true
VITE_ENSEMBLE_MODE=weighted_vote
VITE_PREFER_DONUT_OCR=true

# Optional timeout tuning (milliseconds)
VITE_DONUT_PREDICT_TIMEOUT_MS=120000
VITE_ENSEMBLE_DONUT_TIMEOUT_MS=45000
VITE_ENSEMBLE_GEMINI_TIMEOUT_MS=40000

# ──────────────────────────────────────────────
# Firebase Web Config (from Firebase Console → Project Settings → General → Your apps)
# ──────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
# Local dev safety switch: when omitted/true, skip browser Firebase Storage uploads on localhost
# to avoid noisy CORS failures while DB save continues. Set to false to force upload testing.
VITE_DISABLE_FIREBASE_STORAGE_UPLOAD=true

# ──────────────────────────────────────────────
# MySQL Database
# ──────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=careconnect

# ──────────────────────────────────────────────
# Express API Backend
# ──────────────────────────────────────────────
VITE_API_URL=http://localhost:3001/api
